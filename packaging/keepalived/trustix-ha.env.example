# Per-node TrustIX HA settings. Install as /etc/trustix/<instance>.ha.env.
TRUSTIX_HA_SERVICE_MANAGER=systemd
TRUSTIX_HA_READY_URL=http://127.0.0.1:8787
TRUSTIX_HA_START_TIMEOUT=30
TRUSTIX_HA_STOP_TIMEOUT=15
TRUSTIX_HA_PROMOTION_GRACE=45
TRUSTIX_HA_LOCK_TIMEOUT=120

# Production deployments should fence the previous active node before
# promotion. The hook must be root-owned, executable, and not group/world
# writable. Fencing is required by default; validate the hook on both nodes
# before allowing keepalived to elect either node.
TRUSTIX_HA_REQUIRE_FENCE=1
TRUSTIX_HA_FENCE_HOOK=/usr/local/libexec/trustix/fence-peer.sh

# Optional atomic state/config synchronization hook executed after fencing and
# before trustixd offline config validation.
# TRUSTIX_HA_PRE_PROMOTE_HOOK=/usr/local/libexec/trustix/sync-standby-state.sh
